{
  "name": "duetoday",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run lint && npm run test:navigation-loading && npm run test:progressive-guidance && npm run test:phase3 && npm run test:service && npm run test:pilot && npm run test:intake && npm run test:portal && npm run test:tad-client && npm run test:tad-dual-mode && npm run test:platform-boundary && npm run build",
    "perf:fixtures": "node scripts/setup-performance-fixtures.mjs",
    "perf:pages": "node scripts/benchmark-pages.mjs",
    "test:navigation-loading": "node tests/navigation-loading-contract.mjs",
    "test:progressive-guidance": "node tests/dtc-progressive-guidance-contract.mjs",
    "test:phase3": "rm -rf .phase3-build && tsc -p tests/phase3/tsconfig.json && node tests/phase3/run.cjs",
    "test:service": "node tests/service-workflow-contract.mjs",
    "test:pilot": "node tests/pilot-pack-contract.mjs",
    "test:intake": "node tests/tad-application-contract.mjs",
    "test:portal": "node tests/tad-portal-contract.mjs",
    "test:tad-client": "node tests/tad-client-access-contract.mjs",
    "test:tad-dual-mode": "node tests/tad-dual-mode-contract.mjs",
    "test:platform-boundary": "node tests/dtc-platform-boundary-contract.mjs",
    "test:smoke": "playwright test",
    "test:smoke:headed": "playwright test --headed"
  },
  "dependencies": {
    "@fontsource/archivo-black": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.1",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
